<div class="flex flex-col p-4 bg-base-300 rounded-box">
    <div class="text-xs leading-none text-base-content/60 mb-4">
        {block title}{/block}
    </div>
    <div class="flex mt-auto items-baseline">
        <div class="font-extrabold text-3xl flex-1 leading-none">
            {block text}{/block}
        </div>
        {block icon}{/block}
    </div>
</div>