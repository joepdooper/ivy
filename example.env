APP_KEY=
APP_ENV=development

# -- ERRORS
ERROR_REPORTING=E_ALL
IGNORE_REPEATED_ERRORS=true
DISPLAY_ERRORS=true
LOG_ERRORS=true
ERROR_LOG_FILE=logs/php_error.txt

# -- SERVER
SERVER_PORT=8080

# -- DB
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ivy_db
DB_USERNAME=ivy_db_username
DB_PASSWORD=ivy_db_password

# -- MAIL
MAIL_HOST=mailcatcher
MAIL_SENDER_ADDRESS=noreply@example.com
MAIL_SENDER_NAME="John Doe"
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_SMTP_SECURE=#ssl, tls
MAIL_DEBUG=0

# -- VITE
VITE_FRONTEND_HOST=localhost
VITE_BACKEND_HOST=host.docker.internal
VITE_PORT=5173