{extends file('index.latte')}

{block body}
<div class="flex flex-col min-h-full antialiased">

    {hook('before_header')}
    {block header}
        {include file('include/header.latte')}
    {/block}
    {hook('after_header')}

    {block main}{/block}

    {include file('include/message.latte')}

    {hook('before_footer')}
    {block footer}
        {include file('include/footer.latte')}
    {/block}
    {hook('after_footer')}

</div>
{/block}